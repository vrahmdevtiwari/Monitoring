@model Monitoring.ViewModel.ChangePasswordViewModel

<link rel="stylesheet" href="~/css/cust/partialview.css" asp-append-version="true" />


@Html.AntiForgeryToken()
<div class="modal-header">
    <h1 class="modal-title fs-5" id="exampleModalLabel">Change Password</h1>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body" style="display:flex; flex-direction:column; justify-content:center; justify-items:center;">
    <div class="row">
        <div class="col-xs-12 col-sm-9 col-md-6 col-lg-4 col-xl-5 col-xxl-5">
            <div class="input-container">
                <div class="input-container-title-container"><span class="input-container-title">Current Password</span></div>
                <div class="input-container-password-container">
                    @Html.PasswordFor(model => model.OldPassword, new { @class = "input-container-password" })
                    <span class="input-container-password-icon"><i class="bi bi-eye" data-op="pwd" data-target="OldPassword" data-target-Icon="bi bi-eye-slash" onclick="PasswordIcon(this)"></i></span>
                </div>
                <div class="input-container-error-container">
                        <span asp-validation-for="OldPassword" class="input-container-error"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-xs-12 col-sm-9 col-md-6 col-lg-4 col-xl-5 col-xxl-5">
            <div class="input-container">
                <div class="input-container-title-container"><span class="input-container-title">New Password</span></div>
                <div class="input-container-password-container">
                    @Html.PasswordFor(model => model.NewPassword, new { @class = "input-container-password" })
                    <span class="input-container-password-icon"><i class="bi bi-eye" data-op="pwd" data-target="NewPassword" data-target-Icon="bi bi-eye-slash" onclick="PasswordIcon(this)"></i></span>
                </div>
                <div class="input-container-error-container">
                    <span asp-validation-for="NewPassword" class="input-container-error"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-xs-12 col-sm-9 col-md-6 col-lg-4 col-xl-5 col-xxl-5">
            <div class="input-container">
                <div class="input-container-title-container"><span class="input-container-title">Confirm Password</span></div>
                <div class="input-container-password-container">
                    @Html.PasswordFor(model => model.ConfirmPassword, new { @class = "input-container-password" })
                    <span class="input-container-password-icon"><i class="bi bi-eye" data-op="pwd" data-target="ConfirmPassword" data-target-Icon="bi bi-eye-slash" onclick="PasswordIcon(this)"></i></span>
                </div>
                <div class="input-container-error-container">
                    <span asp-validation-for="ConfirmPassword" class="input-container-error"></span>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal-footer d-flex justify-content-between">
    <div class="msg">
        @if (ViewData.ModelState["Success"] != null && ViewData.ModelState["Success"]?.Errors.Count > 0)
        {
            <span class="success">
                @ViewData.ModelState["Success"]?.Errors.FirstOrDefault()?.ErrorMessage
            </span>
        }

        @if (ViewData.ModelState["Fail"] != null && ViewData.ModelState["Fail"]?.Errors.Count > 0)
        {
            <span class="fail">
                @ViewData.ModelState["Fail"]?.Errors.FirstOrDefault()?.ErrorMessage
            </span>
        }
    </div>
    <div>
        <button id="btnUpdatePassword" type="button" class="btn btn-primary">Update Password</button>
    </div>
</div>

<script type="text/javascript" src="~/js/cust/systeminformation.js" asp-append-version="true"></script>
<script type="text/javascript" src="~/js/cust/cust.js" asp-append-version="true"></script>
<script type="text/javascript">
    $(document).ready(function () {
        $("#btnUpdatePassword").on('click', async function () {
            let $oldpwd = $("#OldPassword").val();
            let $newpwd = $("#NewPassword").val();
            let $confpwd = $("#ConfirmPassword").val();
             let $system = await getSystemInfo();

            let pwd = {
                'OldPassword': $oldpwd,
                'NewPassword': $newpwd,
                'ConfirmPassword': $confpwd,
                'System':$system
            };

            $.ajax({
                url: '@Url.Action("ChangePassword", "Account")',
                type: 'POST',
                data: {
                    chpwd: pwd,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }, // Data sent to the server
                beforeSend: function () {
                    loadingStart(); // Call before sending the request
                },
                success: function (data) {
                    $('#profileModalBody').html('');
                    $('#profileModalBody').html(data); // Load the partial view into the modal
                    $("#ManageProfileModel").modal('show');

                    // Check for success or fail messages in the loaded content
                    var successMessage = $('#profileModalBody .success').text();

                    if (successMessage) {
                        // Close the modal after 2 seconds if successful
                        setTimeout(function () {
                            $("#ManageProfileModel").modal('hide'); // Close the modal
                        }, 2000);
                    } else {
                        // Optionally, handle failure (keep modal open or log it)
                        console.error("invalid request, please refresh and try again");
                    }

                    loadingStop();
                },
                error: function (xhr, status, error) {
                    console.error("Error loading profile data:", error);
                    $('#profileModalBody').html("<p>please refresh and try again after some time</p>"); // Display error message
                    $("#ManageProfileModel").modal('show');
                    loadingStop();
                },
                complete: function () {
                    loadingStop(); // Always called after success or error
                }
            });
        });
    });
</script>
@section Scripts
{
    <script src="~/js/cust/user.js" asp-append-version="true"></script>
}