
@{
    ViewData["Title"] = "Error";
}

<!DOCTYPE html>
<html>
<head>
    <title>Error Page</title>
    <style>
        body {
            margin: 5px 0px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            font-family: Arial, sans-serif;
            
        }
        h1 {
            font-size: 3rem;
            text-align: center;
        }
        p {
            font-size: 1.5rem;
            text-align: center;
        }
        a {
            text-align: center;
        }
        .image-container {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin:0px;
            padding: 2px;
        }

        img {
            min-width: 100px;
            max-width: 300px;
        }

        @@media (max-height: 720px) {
            img {
                width: 250px; 
            }
        }
    </style>
</head>
<body>
    
    <div class="image-container">
        <img src="/img/error404.png" alt="Error Image">
        <h1><b>PAGE NOT FOUND</b></h1>
        <p>We apologize for the inconvenience. Please try again later.</p>
        <a class="btn btn-info" asp-controller="Home" asp-action="Index">Home Page</a>       
    </div>
      
</body>
</html>





