    <script>
        $(document).ready(function(){

            // Manage Profile
            //document.getElementById('ManageProfile').addEventListener('click', function () {
            $("#ManageProfile").on('click', function () {                
                // $('#profileModalBody').attr('width', '350px');
                // data-bs-toggle="modal" data-bs-target="#ManageProfileModel"
                $(this).attr('data-bs-toggle', 'modal').attr('data-bs-target', '#ManageProfileModel');
                $.ajax({
                    url: '@Url.Action("ManageProfile", "Account")', // Replace with your actual controller name
                    type: 'GET',
                    beforeSend: function () {
                        loadingStart(); // Call before sending the request
                    },
                    success: function (data) {
                        $('#profileModalBody').html(data); // Load the partial view into the modal
                        $("#ManageProfileModel").modal('show');
                        // Wait for the DOM to finish rendering
                        requestAnimationFrame(() => {
                            requestAnimationFrame(() => {
                                loadingStop();
                            });
                        });
                    },
                    error: function (xhr, status, error) {
                        console.error("Error loading profile data:", error);
                        $('#profileModalBody').html("<p>Error loading data.</p>"); // Display error message
                        $("#ManageProfileModel").modal('show');
                        loadingStop();
                    },
                    complete: function () {
                        loadingStop(); // Always called after success or error
                    }
                });
            });

            // Change Password
            $("#ChangePassword").on('click', function () {
                // data-bs-toggle="modal" data-bs-target="#ManageProfileModel"
                $(this).attr('data-bs-toggle', 'modal').attr('data-bs-target', '#ManageProfileModel');
                $.ajax({
                    url: '@Url.Action("ChangePassword", "Account")', // Replace with your actual controller name
                    type: 'GET',
                    beforeSend: function () {
                        loadingStart(); // Call before sending the request
                    },
                    success: function (data) {
                        $('#profileModalBody').html(data); // Load the partial view into the modal
                        $("#ManageProfileModel").modal('show');
                        loadingStop();
                    },
                    error: function (xhr, status, error) {
                        console.error("Error loading profile data:", error);
                        $('#profileModalBody').html("<p>Error loading data.</p>"); // Display error message
                        $("#ManageProfileModel").modal('show');
                        loadingStop();
                    },
                    complete: function () {
                        loadingStop(); // Always called after success or error
                    }
                });
            });

            // Registration
            $("#Register").on('click', function () {
                // data-bs-toggle="modal" data-bs-target="#ManageProfileModel"
                $(this).attr('data-bs-toggle', 'modal').attr('data-bs-target', '#ManageProfileModel');
                $.ajax({
                    url: '@Url.Action("Register", "Account")', // Replace with your actual controller name
                    type: 'GET',
                    beforeSend: function () {
                        loadingStart(); // Call before sending the request
                    },
                    success: function (data) {
                        $('#profileModalBody').html(data); // Load the partial view into the modal
                        $("#ManageProfileModel").modal('show');
                        loadingStop();
                    },
                    error: function (xhr, status, error) {
                        console.error("Error loading profile data:", error);
                        $('#profileModalBody').html("<p>Error loading data.</p>"); // Display error message
                        $("#ManageProfileModel").modal('show');
                        loadingStop();
                    },
                    complete: function () {
                        loadingStop(); // Always called after success or error
                    }
                });
            });

            $('button[data-bs-target="#navbarNav"]').click(function () {
                $("#navbarNav").slideToggle();
            });

            // Search Menu Items
            $("#txtSearch").on("keyup", function () {
                let filter = $(this).val().toLowerCase().trim();

                $(".MenucollapseInnerMenuListItem").each(function () {

                    // Get search text from span
                    let txt = $(this).find("span").attr("data-hover");

                    // Prevent error if attribute is missing
                    txt = txt ? txt.toLowerCase() : "";

                    // Show/Hide based on match
                    $(this).toggle(txt.includes(filter));
                });
            }); 

        });

        function openProfile(){
            $("#Profiledropdown").toggle();
        }
        function openNotify(){
            $('#secondNotify').toggle();
        }

        function Close() {
            $("#ManageProfileModel").modal('hide');
        }
        function loadingStart() {
            let spinnerWrapper = document.getElementById('spinner-wrapper');
            spinnerWrapper.style.display = 'flex';
        }

        function loadingStop() {
            let spinnerWrapper = document.getElementById('spinner-wrapper');
            spinnerWrapper.style.display = 'none';
        }
    </script>    
