            </div> *@
            
        </div>  
        
    </div>

    <div class="btn details-bar" onclick="displayTable('apps')">
        <span class="details-link"><h6>Apps</h6></span>
         <span id="apps-bar-plus" class="details-bar-plus"><box-icon name='list-plus' ></box-icon></span>
         <span id="apps-bar-minus" class="details-bar-minus"><box-icon name='list-minus' ></box-icon></span>
    </div>
    <div id="apps-table" class="details-table">
            @{
                var appsModel = ViewBag.AppsModel as List<Monitoring.Models.DTO.AppsDTO>;
            }
            @Html.Partial("Apps", appsModel)
    </div> 


