@model Monitoring.Models.DTO.EASpecificationsDTO

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Overview";
}

<head>
    <link rel="stylesheet" href="~/css/Devices/deviceinfo.css" asp-append-version="true"/>
    <style>
        table{
            font-size:0.9rem;
        }
    </style>
</head>


<div class="Main-Container">
    <h4 id="Main-Title"> Device Overview <span id="assetId">@ViewData["assetId"]</span> </h4>
    
    <div class="details-container">
        <div id="details-list" class="card shadow bg-light mb-3" @* style="max-width: 18rem;" *@>
            <div class="card-header"><h6>Details</h6></div>
            <div class="card-body">
                @* <h5 class="card-title">Light card title</h5> *@
                <div class="card-text details">
                    <table>
                        <tbody>
                            <tr>
                                <td class="title-cells"><b>System Name</b></td>
                                <td>@Model.SystemName</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>Login User</b></td>
                                <td>@Model.LoginUser</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>Domain</b></td>
                                <td>@Model.Domain</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>Privileges</b></td>
                                <td>@Model.Privileges</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>System Manufacturer</b></td>
                                <td>@ViewBag.SystemManufacturer</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>Operating System</b></td>
                                <td>@ViewBag.OS</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>OS Version</b></td>
                                <td>@ViewBag.OSVersion</td>
                            </tr>
                            <tr>
                                <td class="title-cells"><b>OS Build</b></td>
                                <td>@ViewBag.OSBuildVersion</td>
                            </tr>

                            <tr class="extra-details">
                                <td class="title-cells"><b>Public IP Address</b></td>
                                <td>@Model.IPv6Address</td>
                            </tr> 
                            
                            <tr class="extra-details">
                                <td class="title-cells"><b>Last Synced Time</b></td>
                                <td>@Model.LastActive</td>
                            </tr>
                            <tr class="extra-details">
                                <td class="title-cells"><b>System Up Time</b></td>
                                <td>@ViewBag.SystemUptime</td>
                            </tr>

                            

                            @* <tr>
                                <td>System Status</td>
                                <td>@Model.SystemStatus</td>
                            </tr> *@
                            
                            <tr class="extra-details">
                                <td class="title-cells"><b>CPU Name</b></td>
                                <td>@ViewBag.CPUName</td>
                            </tr>

                            <tr class="extra-details">
                                <td class="title-cells"><b>RAM</b></td>
                                <td>@ViewBag.InstalledRAM</td>
                            </tr>

                            <tr class="extra-details">
                                <td class="title-cells"><b>System Model</b></td>
                                <td>@ViewBag.SystemModel</td>
                            </tr>

                            <tr class="extra-details">
                                <td class="title-cells"><b>BIOS Version</b></td>
                                <td>@ViewBag.BIOSVersion</td>
                            </tr>

                            <tr class="extra-details">
                                <td class="title-cells"><b>Serial Number</b></td>
                                <td>@ViewBag.SerialNumber</td>
                            </tr>
                            <tr class="extra-details">
                                <td class="title-cells"><b>IPv4 Address</b></td>
                                <td>@Model.IPv4Address</td>
                            </tr>
                            <tr class="extra-details">
                                <td class="title-cells"><b>MAC Address</b></td>
                                <td>@ViewBag.MACAAddress</td>
                            </tr>
                            <tr class="extra-details">
                                <td class="title-cells"><b>Network</b></td>
                                <td>@Model.NetworkAdapter</td>
                            </tr>
                            <tr>
                                <td><b>Architecture</b></td>
                                <td>@Model.SubnetMask</td>
                            </tr>
                            <tr class="extra-details">
                                <td class="title-cells"><b>GPU</b></td>
                                <td>@ViewBag.GPUName</td>
                            </tr>
                            
                            <tr class="extra-details">
                                <td class="title-cells"><b>Antivirus</b></td>
                                <td>@ViewBag.Antivirus</td>
                            </tr>
                            
                        </tbody>
                    </table>
                        <div id="seemore"><a id="seemoreButton" onclick="showExtraDetails()" class="btn btn-dark">See more...</a></div>

                </div>
            </div>
        </div>
        <div class="other-details-container">
            <div class="location-container card shadow text-white bg-secondary mb-3 " style="height: 370px; width: 500px;">
                <div class="card-header"><h6>Location</h6></div>
                    <div class="card-body">
                        <iframe class="card-text" width="100%" height="100%" frameborder="0" style="border:0" src="https://www.google.com/maps/embed/v1/place?key=AIzaSyCUb6p9T3p-5wwxRYVxOwiR_vGlMxkBA8A&q=@Model.Latitude,@Model.Longitude" allowfullscreen></iframe>
                </div>
            </div>
