                workstation.BIOS_SN = model.BIOS;
                workstation.TrackerID = model.ID;
                workstation.Updatedtime = DateTime.Now;
                var data = await eaAPI.AddWorkstation(workstation);
                if (data != null)
                {
                    return RedirectToAction("Index");
                }
                return BadRequest();
            }
            catch (Exception ex)
            {
                _logger.LogInformation(ex.ToString());
                return BadRequest(ex.ToString());
            }
        }

        [HttpGet]
        public async Task<bool> CheckAssetIDs(string assetID)
        {
            try
            {
                string role = HttpContext.User.FindFirst("role")?.Value;
                List<string> values = JsonConvert.DeserializeObject<List<string>>(role);

                // Now 'values' should contain ["admin", "5"]

                if (values.Count <= 0 || values[0] != "Admin" && values[0] != "SuperAdmin")
                {
                    return false;

                }
                string orgId = HttpContext.User.FindFirst("org")?.Value;
                string user = HttpContext.User.FindFirst("name")?.Value;
                string? token = await HttpContext.GetTokenAsync("access_token");
                var assetIDs = await eaAPI.GetAssetIDs(int.Parse(orgId)); 
                if (!assetIDs.Contains(assetID))
                {
                    return true;
                }
                return false;
            }
            catch (Exception ex)
            {
                _logger.LogInformation(ex.ToString());
                return false;
            }
        }

    }
